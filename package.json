{
  "name": "pi-workbench",
  "version": "0.1.0",
  "description": "Terminal workbench for switching between live Pi sessions using tmux.",
  "type": "module",
  "bin": {
    "pi-workbench": "./dist/cli.js"
  },
  "pi": {
    "extensions": [
      "./dist/extension.js"
    ]
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "tmux",
    "workbench",
    "session-switcher"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "smoke": "npm run build && node dist/cli.js smoke",
    "check": "npm run build && npm test && npm run smoke"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "license": "MIT"
}
